# Exemplo de variaveis para desenvolvimento local e producao.
# Nunca use segredos reais neste arquivo.

# Banco de dados usado pelo Prisma/backend
# Exemplo local: postgresql://postgres:SENHA_LOCAL@localhost:5432/salao
# Producao: use credenciais exclusivas e SSL conforme o provedor
DATABASE_URL="postgresql://DB_USER:DB_PASSWORD@DB_HOST:5432/DB_NAME?schema=public"

# URL publica da API usada no navegador
# Dev: http://localhost:3333
# Producao: https://api.seu-dominio.com
NEXT_PUBLIC_API_URL="https://api.seu-dominio.com"

# URL da API usada no server-side do Next.js e em rewrites/proxy interno
# Dev: http://127.0.0.1:3333
# Producao: http://backend:3333 ou https://api.seu-dominio.com
API_URL="http://backend:3333"

# URL publica do frontend usada pelo NextAuth
# Dev: http://localhost:3000
# Producao: https://app.seu-dominio.com
NEXTAUTH_URL="https://app.seu-dominio.com"

# Segredo do NextAuth
# Gere um valor longo e aleatorio em producao
NEXTAUTH_SECRET="GERAR_SEGREDO_FORTE_E_ALEATORIO"

# Segredo usado para assinar/validar JWT do backend
# Gere um valor longo e aleatorio diferente do NEXTAUTH_SECRET em producao
JWT_SECRET="GERAR_OUTRO_SEGREDO_FORTE_E_ALEATORIO"

# URL publica principal do frontend
# Usada no backend para links publicos, com fallback para NEXTAUTH_URL
# Dev: http://localhost:3000
# Producao: https://app.seu-dominio.com
FRONTEND_URL="https://app.seu-dominio.com"

# Origens extras permitidas no CORS do backend, separadas por virgula
# Dev local pode manter localhost
# Producao: informe somente origens confiaveis
# Exemplo: https://admin.seu-dominio.com,https://painel.parceiro.com
ALLOWED_ORIGINS="https://app.seu-dominio.com"

# Host de bind do backend
# Dev e container: 0.0.0.0
# Ambiente restrito/local especifico: 127.0.0.1
HOST="0.0.0.0"

# Configuracoes publicas do Pix manual no frontend admin
# Ajuste os valores para o canal oficial de atendimento e precos vigentes
NEXT_PUBLIC_PIX_KEY="SUA_CHAVE_PIX_PUBLICA"
NEXT_PUBLIC_SUPPORT_WHATSAPP="55DDDNUMERO"
NEXT_PUBLIC_BASIC_PRICE="R$ 00,00/mês"
NEXT_PUBLIC_PRO_PRICE="R$ 00,00/mês"
