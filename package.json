{
  "name": "salao-agendamento",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "db:up": "docker compose up -d --remove-orphans postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "dev:stop": "bash ./scripts/dev-stop.sh",
    "dev": "bash ./scripts/dev-with-env.sh .env",
    "dev:ngrok": "bash ./scripts/dev-with-env.sh .env.ngrok",
    "build": "npm --workspace=frontend run build && npm --workspace=backend run build",
    "start": "npm --workspace=backend run start:prod",
    "seed": "npm --workspace=backend run seed"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "concurrently": "^8.2.2",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "crypto": "^1.0.1"
  }
}
