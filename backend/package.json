{
  "name": "salao-backend",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "start:prod": "node dist/main.js",
    "build": "tsc -p tsconfig.build.json",
    "prisma:generate": "PRISMA_GENERATE_SKIP_AUTOINSTALL=true node --env-file=../.env ../node_modules/prisma/build/index.js generate --schema ./prisma/schema.prisma",
    "prisma:migrate": "node --env-file=../.env ../node_modules/prisma/build/index.js migrate dev --schema ./prisma/schema.prisma",
    "prisma:push": "node --env-file=../.env ../node_modules/prisma/build/index.js db push --schema ./prisma/schema.prisma",
    "seed": "npx ts-node --env-file=../.env prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.2",
    "@nestjs/core": "^10.3.2",
    "@nestjs/platform-express": "^10.3.2",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "luxon": "^3.7.2",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^5.0.1",
    "rxjs": "^7.8.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "zod": "^3.23.2"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.1",
    "@types/node": "^20.19.39",
    "prisma": "^5.22.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
